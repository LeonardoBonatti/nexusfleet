# Variáveis de Configuração do Sistema

# Definindo a porta em que o servidor irá rodar
PORT=3000

# Configurações do Banco de Dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=sua_senha_aqui
DB_NAME=fuel_control_db

# Segurança e JWT
JWT_SECRET=super_secret_key_change_me
JWT_EXPIRATION=24h

# Configurações de API Externa (Ex: Google Maps)
GOOGLE_MAPS_API_KEY=sua_chave_do_google_maps_aqui
FUEL_API_URL=https://api.temp-fuel.example.com
